"""
Identify Cluster Biological Identities by Comparing Marker Genes to Paper
 
Matches your clusters to the paper's cell types based on marker gene expression.
"""
# Note: Code formatting and troubleshooting assisted by Claude AI (Anthropic)

import scanpy as sc
import pandas as pd
from pathlib import Path
 
# Load your analyzed data
BASE_DIR = Path("/scratch/alice/t/tlti1/altpipeline")
adata_file = BASE_DIR / "results" / "scanpy_analysis.h5ad"
 
print("=" * 70)
print("CLUSTER IDENTITY ANALYSIS")
print("=" * 70)
print()
 
print("Loading analyzed data...")
adata = sc.read(adata_file)
print(f"Loaded: {adata.n_obs} cells, {adata.n_vars} genes")
print()
 
# Convert Ensembl IDs to gene symbols
print("Converting Ensembl IDs to gene symbols...")
# Extract gene symbols from Ensembl IDs in the reference transcriptome
import gzip
 
gene_id_to_symbol = {}
ref_file = BASE_DIR / "reference" / "gencode.v46.transcripts.fa.gz"
 
with gzip.open(ref_file, 'rt') as f:
    for line in f:
        if line.startswith('>'):
            # Example: >ENST00000456328.2|ENSG00000290825.1|...|DDX11L2|...
            parts = line.strip().split('|')
            if len(parts) >= 6:
                gene_id = parts[1].split('.')[0]  # ENSG00000290825
                gene_symbol = parts[5]  # DDX11L2
                if gene_symbol and gene_symbol != '':
                    gene_id_to_symbol[gene_id] = gene_symbol
 
print(f"Mapped {len(gene_id_to_symbol)} Ensembl IDs to gene symbols")
 
# Add gene symbols to adata
adata.var['gene_symbol'] = [gene_id_to_symbol.get(gid, gid) for gid in adata.var_names]
 
# Recompute marker genes with gene symbols for display
print("Recomputing marker genes with gene symbols...")
sc.tl.rank_genes_groups(adata, 'leiden', method='wilcoxon')
print()
 
# Paper's known marker genes for each cell type
PAPER_MARKERS = {
    "Dorsal forebrain NPCs": ["PAX6", "SOX2", "HES1", "SOX9", "FABP7", "VIM", "NES"],
    "Dorsal forebrain neurons": ["NEUROD6", "BCL11A", "BCL11B", "NFIB", "STMN2", "DCX", "TUBB3"],
    "Cycling progenitors": ["MKI67", "TOP2A", "CENPF", "PCNA", "CDK1", "CCNB1", "NUSAP1"],
    "Ventral forebrain": ["DLX2", "DLX5", "GAD1", "GAD2", "NKX2-1"],
    "Mesenchymal cells": ["COL1A1", "COL1A2", "COL3A1", "DCN", "LUM", "SPARC", "VIM"],
    "Radial glia": ["GFAP", "VIM", "HOPX", "FAM107A", "TNC", "LIFR"],
    "OTX2+ cells": ["OTX2", "EN1", "EN2"],
    "Signaling centers": ["WLS", "RSPO1", "RSPO2", "RSPO3", "WNT2B", "WNT3A"],
}
 
print("Known marker genes from paper:")
for cell_type, genes in PAPER_MARKERS.items():
    print(f"  {cell_type}: {', '.join(genes[:5])}...")
print()
 
# Check which markers are present in your data (by gene symbol)
print("Checking marker gene availability in dataset:")
available_markers = {}
gene_symbols_in_data = set(adata.var['gene_symbol'])
 
for cell_type, genes in PAPER_MARKERS.items():
    present = [g for g in genes if g in gene_symbols_in_data]
    missing = [g for g in genes if g not in gene_symbols_in_data]
    available_markers[cell_type] = present
    if missing:
        print(f"  {cell_type}: {len(present)}/{len(genes)} markers present (missing: {', '.join(missing)})")
    else:
        print(f"  {cell_type}: All {len(genes)} markers present ✓")
print()
 
# Calculate mean expression of each marker set in each cluster
print("Calculating marker expression per cluster...")
print()
 
cluster_identities = {}
for cluster in sorted(adata.obs['leiden'].unique(), key=int):
    print(f"=== Cluster {cluster} ===")
    
    # Get cells in this cluster
    cluster_mask = adata.obs['leiden'] == cluster
    cluster_data = adata[cluster_mask, :]
    
    # Print top 10 marker genes for this cluster (with gene symbols)
    cluster_gene_ids = adata.uns['rank_genes_groups']['names'][cluster][:10]
    cluster_genes = [adata.var.loc[gid, 'gene_symbol'] if gid in adata.var_names else gid 
                     for gid in cluster_gene_ids]
    print(f"Top markers: {', '.join(cluster_genes)}")
    
    # Calculate average expression of each cell type's markers
    scores = {}
    for cell_type, markers in available_markers.items():
        if len(markers) == 0:
            continue
        # Get Ensembl IDs for these gene symbols
        marker_ids = [adata.var_names[adata.var['gene_symbol'] == m].tolist()[0] 
                      for m in markers 
                      if m in adata.var['gene_symbol'].values]
        
        if len(marker_ids) == 0:
            continue
            
        # Get expression of these markers in this cluster
        marker_expr = cluster_data[:, marker_ids].X.mean(axis=0)
        mean_score = marker_expr.mean()
        scores[cell_type] = mean_score
    
    # Find best matching cell type
    if scores:
        best_match = max(scores, key=scores.get)
        cluster_identities[cluster] = best_match
        print(f"Best match: {best_match} (score: {scores[best_match]:.3f})")
        print(f"All scores: {dict(sorted(scores.items(), key=lambda x: -x[1])[:3])}")
    
    print()
 
# Summary
print("=" * 70)
print("CLUSTER IDENTITY SUMMARY")
print("=" * 70)
for cluster in sorted(cluster_identities.keys(), key=int):
    n_cells = (adata.obs['leiden'] == cluster).sum()
    print(f"Cluster {cluster} ({n_cells} cells): {cluster_identities[cluster]}")
print()
 
# Save identities
identity_file = BASE_DIR / "results" / "cluster_identities.txt"
with open(identity_file, 'w') as f:
    f.write("Cluster Identity Assignments\n")
    f.write("=" * 70 + "\n\n")
    for cluster in sorted(cluster_identities.keys(), key=int):
        n_cells = (adata.obs['leiden'] == cluster).sum()
        f.write(f"Cluster {cluster} ({n_cells} cells): {cluster_identities[cluster]}\n")
 
print(f"Saved identities to: {identity_file}")
print()
 
# Add identities to AnnData
adata.obs['cell_type'] = adata.obs['leiden'].map(cluster_identities)
adata.write(adata_file)
print(f"Updated AnnData with cell types: {adata_file}")

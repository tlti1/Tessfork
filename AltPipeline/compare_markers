# Load Ensembl to gene symbol mapping
print("Loading gene ID mapping...")
ref_file = BASE_DIR / "reference" / "gencode.v46.transcripts.fa.gz"
gene_id_to_symbol = {}
 
with gzip.open(ref_file, 'rt') as f:
    for line in f:
        if line.startswith('>'):
            parts = line.strip().split('|')
            if len(parts) >= 6:
                gene_id = parts[1].split('.')[0]
                gene_symbol = parts[5]
                if gene_symbol:
                    gene_id_to_symbol[gene_id] = gene_symbol
 

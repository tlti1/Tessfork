# Submit Salmon jobs ONE AT A TIME (no arrays)
# Processes all 734 samples sequentially
#Note: Code formatting and troubleshooting assisted by Claude AI (Anthropic)
# Run: nohup bash 06_submit_salmon_sequential.sh > salmon_sequential.log 2>&1 &
 
BASE_DIR="/scratch/alice/t/tlti1/altpipeline"
METADATA="$BASE_DIR/metadata/SRR_Acc_List.txt"
INDEX_DIR="$BASE_DIR/salmon_index"
FASTQ_DIR="$BASE_DIR/fastq"
QUANT_DIR="$BASE_DIR/salmon_quant"
 
echo "=== Sequential Salmon Submission ==="
echo "Start: $(date)"
echo ""
 
# Load salmon module
module load salmon/1.10.2-5pennjh
 
TOTAL=$(wc -l < $METADATA)
COUNT=0
 
while read SRR; do
    COUNT=$((COUNT + 1))
    
    echo "[$COUNT/$TOTAL] Processing $SRR..."
    
    # Skip if already done
    if [ -f "$QUANT_DIR/$SRR/quant.sf" ]; then
        echo "  Already quantified, skipping"
        continue
    fi
    
    # Run Salmon directly (no SLURM submission)
    salmon quant \
        -i $INDEX_DIR \
        -l A \
        -1 $FASTQ_DIR/${SRR}_1.fastq \
        -2 $FASTQ_DIR/${SRR}_2.fastq \
        -o $QUANT_DIR/$SRR \
        -p 4 \
        --validateMappings \
        --gcBias \
        --seqBias \
        > $BASE_DIR/logs/salmon_${SRR}.out 2> $BASE_DIR/logs/salmon_${SRR}.err
    
    if [ $? -eq 0 ]; then
        echo "  ✓ Complete"
    else
        echo "  ✗ Failed"
    fi
    
    # Progress update every 50
    if [ $((COUNT % 50)) -eq 0 ]; then
        echo ""
        echo "=== Progress: $COUNT/$TOTAL ==="
        du -sh $QUANT_DIR
        echo ""
    fi
    
done < $METADATA
 
echo ""
echo "=== All samples complete! ==="
echo "End: $(date)"
echo ""
echo "Results:"
ls $QUANT_DIR/*/quant.sf 2>/dev/null | wc -l

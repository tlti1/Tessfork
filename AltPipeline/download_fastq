# Activate conda environment with SRA toolkit
module load astroconda
source ~/.bashrc
conda activate myenv
 
BASE_DIR="/scratch/alice/t/tlti1/altpipeline"
FASTQ_DIR="$BASE_DIR/fastq"
METADATA="$BASE_DIR/metadata/SraAccList.txt"

# Verify fasterq-dump is available
which fasterq-dump
fasterq-dump --version
 
TOTAL=$(wc -l < $METADATA)
echo "Total samples: $TOTAL"
echo ""
 
mkdir -p $BASE_DIR/sra_cache
vdb-config --prefetch-to-cwd
 
COUNT=0
while read SRR; do
    COUNT=$((COUNT + 1))
    echo "[$COUNT/$TOTAL] Downloading $SRR..."
    
    if [ -f "$FASTQ_DIR/${SRR}_1.fastq" ] && [ -f "$FASTQ_DIR/${SRR}_2.fastq" ]; then
        echo "  Already exists, skipping"
        continue
    fi
    
    fasterq-dump $SRR \
        --split-files \
        --threads 4 \
        --outdir $FASTQ_DIR \
        --progress \
        --temp $BASE_DIR/sra_cache
    
    if [ $((COUNT % 50)) -eq 0 ]; then
        echo ""
        echo "Progress: $COUNT/$TOTAL"
        du -sh $FASTQ_DIR
        echo ""
    fi
    
done < $METADATA
 
rm -rf $BASE_DIR/sra_cache
